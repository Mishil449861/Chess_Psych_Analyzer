# Copy this to .env and customize. All values are optional.

# --- Database ---
# CHESS_PSYCH_DB=/path/to/data.db

# --- Stockfish ---
# STOCKFISH_PATH=/usr/games/stockfish
# STOCKFISH_DEPTH=12
# STOCKFISH_THREADS=1
# STOCKFISH_HASH_MB=64

# --- Chess.com API ---
# Chess.com's terms require a real User-Agent identifying your app/contact.
CHESSCOM_USER_AGENT=ChessPsych/0.1 (https://github.com/Mishil449861/Chess_Psych_Analyzer)
# CHESSCOM_TIMEOUT=30
# CHESSCOM_RETRY_MAX=4
# CHESSCOM_RETRY_BACKOFF=1.5

# --- LLM (Ollama) ---
# OLLAMA_URL=http://127.0.0.1:11434/api/generate
# OLLAMA_MODEL=llama3
# OLLAMA_TIMEOUT=120

# --- Analysis tuning ---
# BLUNDER_MIN_PLY=6
# CLUSTER_MIN_SIZE=3

# --- Logging ---
# LOG_LEVEL=INFO
